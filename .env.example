# Copy this file to `.env` and edit values.
# The `.env` file is ignored by git.
#
# Generate a strong token:
#   openssl rand -hex 32
#
# Multiple tokens are supported (comma-separated).
API_KEYS=replace-with-a-strong-token

# Server listen address
HTTP_ADDR=:8080

# SQLite data file
SQLITE_PATH=./data/proxypool.db

# Optional: SQLite tuning for multi-core machines
# SQLITE_MAX_OPEN_CONNS=4
# SQLITE_BUSY_TIMEOUT=15s
# SQLITE_WAL_SIZE_LIMIT=100m
# SQLITE_WAL_AUTOCHECKPOINT=256
# STATS_QUERY_TIMEOUT=3s
# INVALID_NODE_RETENTION=72h

# Optional: if set, the service can call its own `/probe/echo` via a reachable URL
# to estimate anonymity (transparent/anonymous/elite).
# PUBLIC_BASE_URL=http://YOUR_SERVER_IP:8080

# Optional: offline GeoIP enrichment (country/ASN)
# GEOIP_COUNTRY_MMDB=/geoip/GeoLite2-Country.mmdb
# GEOIP_ASN_MMDB=/geoip/GeoLite2-ASN.mmdb

# Lightweight mode suggestions (1c1g)
# GOMAXPROCS=1
# NODEMAVEN_ENABLED=false
# PURITY_LOOKUP_ENABLED=false
